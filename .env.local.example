# Google OAuth Configuration
# 從 Google Cloud Console 獲取 Client ID
# 請參考: backend/FRONTEND_INTEGRATION.md
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL
# 本地開發環境使用 http://localhost:8000
# 生產環境請修改為實際的 API URL（例如：https://api.yourdomain.com）
NEXT_PUBLIC_API_URL=http://localhost:8000
